meta {
  name: Login
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/login
  body: json
  auth: none
}

headers {
  Accept: application/json
}

body:json {
  {
    "email": "test@example.com",
    "password": "password"
  }
}

assert {
  res.status: eq 200
  res.body.token: isString
}

script:post-response {
  if (res.body.token) {
    bru.setEnvVar("authToken", res.body.token);
  }
}
