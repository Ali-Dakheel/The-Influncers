meta {
  name: Emergency Stop
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/brand/emergency-stop
  body: json
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

headers {
  Accept: application/json
}

body:json {
  {
    "reason": "Brand crisis - all campaigns paused while we investigate."
  }
}

assert {
  res.status: eq 200
  res.body.paused_count: isNumber
}
