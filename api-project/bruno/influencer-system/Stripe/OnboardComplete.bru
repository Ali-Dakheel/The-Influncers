meta {
  name: Complete Stripe Onboarding (stub)
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/me/stripe/onboard/complete
  body: none
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

headers {
  Accept: application/json
}

assert {
  res.status: eq 200
  res.body.onboarded: eq true
}
